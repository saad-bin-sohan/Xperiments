rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function affectsOnly(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    match /users/{userId} {
      allow create: if isSelf(userId) &&
        request.resource.data.isAdmin == false &&
        request.resource.data.disabled == false &&
        (!('experimentCount' in request.resource.data) || request.resource.data.experimentCount == 0);

      allow read: if isSelf(userId) || isAdmin();

      allow update: if isAdmin() ||
        (isSelf(userId) &&
          affectsOnly(['displayName', 'email', 'photoURL', 'preferences']));

      allow delete: if isAdmin();

      match /devices/{deviceId} {
        allow read, write: if isSelf(userId);
      }
    }

    match /labs/{labId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /experiments/{experimentId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /checkins/{checkinId} {
        allow read, write: if isSignedIn() &&
          get(/databases/$(database)/documents/experiments/$(experimentId)).data.userId == request.auth.uid;
      }
    }

    match /journalEntries/{entryId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /gallery/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
